# Public (safe to expose in the browser)
# Production: set to the live origin (https://www.phycalcpro.com) for correct sitemap, canonicals, and OG URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FREE_LAUNCH=true
NEXT_PUBLIC_VALIDATION_MODE=
NEXT_PUBLIC_DEV_ENTITLEMENT=
# Search Console / Bing ownership (optional — meta tags only when set; see docs/SEO-Indexing.md)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Supabase Auth + cloud persistence (opt-in)
NEXT_PUBLIC_SUPABASE_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Licensing / Stripe (optional for free launch)
LICENSE_SIGNING_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_DONATION=

# Support feedback email (optional)
RESEND_API_KEY=
FEEDBACK_NOTIFY_EMAIL=
RESEND_FROM_EMAIL=

# Monitoring (optional — leave blank to disable Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
