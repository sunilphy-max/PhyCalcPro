{
  "name": "phycalcpro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:layout && node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint",
    "validate:layout": "node scripts/validate-module-registry.mjs && node scripts/validate-product-layout.mjs",
    "validate:maturity-gates": "tsx scripts/validate-maturity-gates.ts",
    "generate:verification-template": "node scripts/generate-verification-template.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:product-seo-layouts": "node scripts/generate-product-seo-layouts.mjs",
    "test:verification": "tsx scripts/run-verification.ts && tsx scripts/validate-maturity-gates.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.3",
    "plotly.js": "^3.5.0",
    "plotly.js-dist-min": "^3.5.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/plotly.js": "^3.0.10",
    "@types/plotly.js-basic-dist": "^1.54.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "xlsx": "^0.18.5"
  }
}
